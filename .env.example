VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Sentry crash reporting (DSN is a public token, safe to ship in client).
# Get from sentry.io → project settings → client keys (DSN).
VITE_SENTRY_DSN=

# Giphy API
VITE_GIPHY_API_KEY=your-giphy-api-key-here

# Agora SDK (for voice/video calls)
VITE_AGORA_APP_ID=your-agora-app-id-here

# RevenueCat (for subscriptions)
VITE_REVENUECAT_ANDROID_KEY=your-revenuecat-android-key
VITE_REVENUECAT_IOS_KEY=your-revenuecat-ios-key
